{
  "name": "@azeth/common",
  "version": "0.2.0",
  "type": "module",
  "description": "Shared types, constants, ABIs, and errors for the Azeth trust infrastructure",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/azeth-protocol/common.git"
  },
  "homepage": "https://azeth.ai",
  "keywords": [
    "azeth",
    "machine-economy",
    "trust-registry",
    "erc-8004",
    "erc-4337",
    "smart-accounts",
    "x402"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./abis": {
      "types": "./dist/abis/index.d.ts",
      "import": "./dist/abis/index.js"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@changesets/cli": "^2.27.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "release": "pnpm build && changeset publish"
  }
}